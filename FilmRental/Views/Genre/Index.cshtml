
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Views/Genre/Index.cshtml -->
@model List<EntityLayer.Concrete.Genre>
@{
    ViewData["Title"] = "Film Türleri";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8">Film Türleri</h1>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
        @foreach (var item in Model)
        {
            <a href="/Genre/Movies/@item.Id"
               class="bg-white rounded-lg p-6 shadow-lg hover:shadow-xl transition duration-300 transform hover:-translate-y-1">
                <div class="text-center">
                    <h2 class="text-xl font-semibold text-gray-800 mb-2">@item.Name</h2>
                    <p class="text-gray-600">@(item.MovieGenres?.Count() ?? 0) Film</p>
                </div>
            </a>
        }
    </div>
</div>