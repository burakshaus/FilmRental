@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@using EntityLayer.Concrete
<!-- Views/Home/Index.cshtml -->
@model List<Movie>

@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
    @foreach (var movie in Model)

    {
        <div class="bg-gray-800 rounded-lg overflow-hidden shadow-lg transform transition hover:scale-105">
            <a href="/Movies/Details/@movie.Id">
                <img src="@(string.IsNullOrEmpty(movie.PosterPath) ? "/images/placeholder.jpg" : $"https://image.tmdb.org/t/p/w500{movie.PosterPath}")"
                     alt="@movie.Title"
                     class="w-full h-96 object-cover">
                <div class="p-4">
                    <h2 class="text-xl font-bold mb-2 line-clamp-1">@movie.Title</h2>
                    <div class="flex items-center mb-2">
                        <div class="flex items-center">
                            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                            <span class="ml-2 text-yellow-400">@(movie.ImdbRating?.ToString("0.0") ?? "N/A")</span>
                        </div>
                        <span class="mx-2">•</span>
                        <span class="text-gray-400">@(movie.ReleaseDate?.Year.ToString() ?? "N/A")</span>
                    </div>
                    <div class="flex flex-wrap gap-2 mb-2">
                        @foreach (var genre in movie.MovieGenres.Take(3))
                        {
                            <span class="px-2 py-1 text-xs bg-blue-600 rounded-full">@genre.Genre.Name</span>
                        }
                    </div>
                    <p class="text-gray-400 text-sm line-clamp-2">@movie.Overview</p>
                </div>
            </a>
        </div>
    }
</div>