
@{
    ViewData["Title"] = "Movies";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Views/Genre/Movies.cshtml -->
@model List<EntityLayer.Concrete.Movie>
@{
    ViewData["Title"] = $"{ViewBag.GenreName} Filmleri";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold">@ViewBag.GenreName Filmleri</h1>
        <a href="/Genre" class="text-blue-600 hover:text-blue-800">
            ← Tüm Türler
        </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        @foreach (var item in Model)
        {
            <div class="bg-white rounded-lg overflow-hidden shadow-lg">
                <a href="/Movies/Details/@item.Id">
                    @if (!string.IsNullOrEmpty(item.PosterPath))
                    {
                        <img src="@(item.PosterPath.StartsWith("http") ? item.PosterPath : $"https://image.tmdb.org/t/p/w500{item.PosterPath}")"
                             alt="@item.Title"
                             class="w-full h-96 object-cover">
                    }
                    else
                    {
                        <div class="w-full h-96 bg-gray-200 flex items-center justify-center">
                            <span class="text-gray-400">Görsel Yok</span>
                        </div>
                    }
                    <div class="p-4">
                        <h2 class="text-xl font-bold mb-2 line-clamp-1">@item.Title</h2>

                        <div class="flex items-center mb-2">
                            @if (item.ImdbRating.HasValue)
                            {
                                <div class="flex items-center">
                                    <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                    </svg>
                                    <span class="ml-1 text-gray-600">@item.ImdbRating.Value.ToString("0.0")</span>
                                </div>
                            }

                            @if (item.ReleaseDate.HasValue)
                            {
                                <span class="mx-2 text-gray-400">•</span>
                                <span class="text-gray-600">@item.ReleaseDate.Value.Year</span>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(item.Overview))
                        {
                            <p class="text-gray-600 text-sm line-clamp-2">@item.Overview</p>
                        }
                    </div>
                </a>
            </div>
        }
    </div>
</div>