@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@using EntityLayer.Concrete
<!-- Views/Home/Index.cshtml -->
@model List<Movie>

@{
    ViewData["Title"] = "Filmler";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    // Güvenli tür dönüşümleri (null korumaları)
    int? selectedGenreId = ViewBag.SelectedGenreId as int?;
    double? selectedMinRating = ViewBag.SelectedMinRating as double?;
    int? selectedYear = ViewBag.SelectedYear as int?;
}

<div class="mb-8 bg-gray-800 p-6 rounded-xl shadow-lg border border-gray-700">
    <h2 class="text-xl font-bold mb-4 text-white flex items-center">
        <svg class="w-6 h-6 mr-2 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
        @Localizer["FilterMovies"]
    </h2>
    <form action="/Movies" method="get" class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
        
        <!-- Tür Seçimi -->
        <div>
            <label for="genreId" class="block text-sm font-medium text-gray-300 mb-1">@Localizer["Genre"]</label>
            <select id="genreId" name="genreId" class="w-full bg-gray-700 border border-gray-600 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-indigo-500">
                <option value="">@Localizer["All"]</option>
                @if (ViewBag.Genres != null)
                {
                    foreach (var genre in ViewBag.Genres)
                    {
                        if (selectedGenreId == genre.Id)
                        {
                            <option value="@genre.Id" selected>@genre.Name</option>
                        }
                        else
                        {
                            <option value="@genre.Id">@genre.Name</option>
                        }
                    }
                }
            </select>
        </div>

        <!-- Minimum Puan -->
        <div>
            <label for="minRating" class="block text-sm font-medium text-gray-300 mb-1">@Localizer["MinRating"]</label>
            <select id="minRating" name="minRating" class="w-full bg-gray-700 border border-gray-600 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-indigo-500">
                <option value="">@Localizer["All"]</option>
                @foreach (var val in new[] { 9, 8, 7, 6, 5 })
                {
                    if (selectedMinRating == val)
                    {
                        <option value="@val" selected>@val.ToString("+")</option>
                    }
                    else
                    {
                        <option value="@val">@val.ToString("+")</option>
                    }
                }
            </select>
        </div>

        <!-- Çıkış Yılı -->
        <div>
            <label for="year" class="block text-sm font-medium text-gray-300 mb-1">@Localizer["ReleaseYear"]</label>
            <select id="year" name="year" class="w-full bg-gray-700 border border-gray-600 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-indigo-500">
                <option value="">@Localizer["All"]</option>
                @foreach (var val in new[] { 2024, 2020, 2010, 2000 })
                {
                    if (selectedYear == val)
                    {
                        <option value="@val" selected>@val @Localizer["AndLater"]</option>
                    }
                    else
                    {
                        <option value="@val">@val @Localizer["AndLater"]</option>
                    }
                }
            </select>
        </div>

        <!-- Butonlar -->
        <div class="flex space-x-2">
            <button type="submit" class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded-lg transition duration-200">
                @Localizer["Apply"]
            </button>
            <a href="/Movies" class="bg-gray-600 hover:bg-gray-500 text-white font-medium py-2 px-4 rounded-lg transition duration-200 text-center flex items-center justify-center" title="@Localizer["ClearFilters"]">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </a>
        </div>
    </form>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
    @foreach (var movie in Model)

    {
        <div class="bg-gray-800 rounded-lg overflow-hidden shadow-lg transform transition hover:scale-105">
            <a href="/Movies/Details/@movie.Id">
                <img src="@(string.IsNullOrEmpty(movie.PosterPath) ? "/images/placeholder.jpg" : (movie.PosterPath.StartsWith("http") ? movie.PosterPath : $"https://image.tmdb.org/t/p/w500{movie.PosterPath}"))"
                     alt="@movie.Title"
                     class="w-full h-96 object-cover">
                <div class="p-4">
                    <h2 class="text-xl font-bold mb-2 line-clamp-1">@movie.Title</h2>
                    <div class="flex items-center mb-2">
                        <div class="flex items-center">
                            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                            <span class="ml-2 text-yellow-400">@(movie.ImdbRating?.ToString("0.0") ?? "N/A")</span>
                        </div>
                        <span class="mx-2">•</span>
                        <span class="text-gray-400">@(movie.ReleaseDate?.Year.ToString() ?? "N/A")</span>
                    </div>
                    <div class="flex flex-wrap gap-2 mb-2">
                        @foreach (var genre in movie.MovieGenres.Take(3))
                        {
                            <span class="px-2 py-1 text-xs bg-blue-600 rounded-full">@genre.Genre.Name</span>
                        }
                    </div>
                    <p class="text-gray-400 text-sm line-clamp-2">@movie.Overview</p>
                </div>
            </a>
        </div>
    }
</div>