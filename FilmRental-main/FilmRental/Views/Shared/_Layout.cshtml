<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Filmvc</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/@@n8n/chat/dist/style.css" rel="stylesheet">
    <style>
        #n8n-chat {
            position: fixed !important;
            bottom: 20px !important;
            right: 20px !important;
            z-index: 9999 !important;
        }

        .n8n-chat-bubble {
            background-color: #4f46e5 !important;
            border-radius: 50% !important;
            width: 60px !important;
            height: 60px !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            cursor: pointer !important;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1) !important;
        }

        .n8n-chat-window {
            width: 380px !important;
            height: 600px !important;
            border-radius: 12px !important;
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1) !important;
            background-color: white !important;
            color: black !important;
        }

        .n8n-chat-header {
            background-color: #4f46e5 !important;
            color: white !important;
            padding: 16px !important;
            border-top-left-radius: 12px !important;
            border-top-right-radius: 12px !important;
        }

        .n8n-chat-messages {
            padding: 16px !important;
            height: calc(100% - 120px) !important;
            overflow-y: auto !important;
        }

        .n8n-chat-input {
            border: 1px solid #e2e8f0 !important;
            border-radius: 8px !important;
            padding: 12px !important;
            margin: 16px !important;
            width: calc(100% - 32px) !important;
        }
    </style>
</head>
<body class="bg-gray-900 text-white min-h-screen">
    @{
        var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.Name;
        var returnUrl = Context.Request.Path + Context.Request.QueryString;
    }
    <nav class="bg-gray-800 shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center">
                    <a href="/" class="text-xl font-bold">@Localizer["AppTitle"]</a>
                    <div class="hidden md:block ml-10">
                        <div class="flex items-baseline space-x-3">
                            <a href="/Movies" class="text-gray-300 hover:text-white px-3 py-2 rounded-md">@Localizer["Movies"]</a>
                            <a href="/Genre" class="text-gray-300 hover:text-white px-3 py-2 rounded-md">@Localizer["Genres"]</a>
                            <a href="/Actor" class="text-gray-300 hover:text-white px-3 py-2 rounded-md">@Localizer["Actors"]</a>
                            <a href="/Rental" class="text-gray-300 hover:text-white px-3 py-2 rounded-md">@Localizer["Rentals"]</a>
                        </div>
                    </div>
                </div>
                <!-- Search Bar -->
                <div class="flex-1 flex justify-center px-2 lg:ml-6 lg:justify-end">
                    <div class="max-w-lg w-full lg:max-w-xs">
                        <label for="search" class="sr-only">@Localizer["Search"]</label>
                        <form action="/Movies/Search" method="get" class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                                </svg>
                            </div>
                            <input id="search" name="q" class="block w-full pl-10 pr-3 py-2 border border-transparent rounded-md leading-5 bg-gray-700 text-gray-300 placeholder-gray-400 focus:outline-none focus:bg-white focus:text-gray-900 sm:text-sm transition duration-150 ease-in-out" placeholder="@Localizer["Search"]" type="search">
                        </form>
                    </div>
                </div>
                <!-- Language Switcher -->
                <div class="relative ml-4 flex-shrink-0">
                    <div class="flex items-center space-x-1">
                        <a href="@Url.Action("ChangeCulture", "Language", new { culture = "tr-TR", returnUrl = returnUrl })"
                           class="@(currentCulture == "tr-TR" ? "bg-indigo-600 text-white" : "text-gray-400 hover:text-white hover:bg-gray-700") px-2 py-1 rounded text-sm font-medium transition">
                            🇹🇷 TR
                        </a>
                        <a href="@Url.Action("ChangeCulture", "Language", new { culture = "en-US", returnUrl = returnUrl })"
                           class="@(currentCulture == "en-US" ? "bg-indigo-600 text-white" : "text-gray-400 hover:text-white hover:bg-gray-700") px-2 py-1 rounded text-sm font-medium transition">
                            🇬🇧 EN
                        </a>
                        <a href="@Url.Action("ChangeCulture", "Language", new { culture = "de-DE", returnUrl = returnUrl })"
                           class="@(currentCulture == "de-DE" ? "bg-indigo-600 text-white" : "text-gray-400 hover:text-white hover:bg-gray-700") px-2 py-1 rounded text-sm font-medium transition">
                            🇩🇪 DE
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="container mx-auto px-4 py-8">
        @RenderBody()
    </main>

    <!-- AI Chat Widget UI -->
    <div id="ai-chat-widget" class="fixed bottom-6 right-6 z-50">
        <!-- Chat Button -->
        <button id="chat-toggle-btn" class="w-14 h-14 bg-indigo-600 rounded-full flex items-center justify-center text-white shadow-lg hover:bg-indigo-700 transition transform hover:scale-110 focus:outline-none focus:ring-4 focus:ring-indigo-300">
            <svg id="chat-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
            <svg id="chat-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <!-- Chat Window -->
        <div id="chat-window" class="hidden absolute bottom-20 right-0 w-80 sm:w-96 bg-gray-800 rounded-2xl shadow-2xl border border-gray-700 overflow-hidden flex flex-col transition-all duration-300" style="height: 500px; max-height: 80vh;">
            <!-- Header -->
            <div class="bg-indigo-600 p-4 flex justify-between items-center text-white">
                <div>
                    <h3 class="font-bold text-lg">Film Asistanı 🤖</h3>
                    <p class="text-xs text-indigo-200">Yapay Zeka Destekli (Gemini)</p>
                </div>
            </div>

            <!-- Messages Area -->
            <div id="chat-messages" class="flex-1 p-4 overflow-y-auto space-y-4 custom-scrollbar bg-gray-900">
                <!-- Welcome Bot Message -->
                <div class="flex items-start mb-4">
                    <div class="bg-gray-700 text-gray-100 p-3 rounded-2xl rounded-tl-none max-w-[80%] text-sm shadow whitespace-pre-wrap">Merhaba! Film arşivimize hoş geldiniz. 🎬 Size en iyi filmleri önermek için buradayım. Bugün nasıl bir film arıyorsunuz?</div>
                </div>
            </div>

            <!-- Input Area -->
            <div class="p-3 bg-gray-800 border-t border-gray-700">
                <form id="chat-form" class="flex items-center gap-2">
                    <input type="text" id="chat-input" placeholder="Bir film sor..." class="flex-1 bg-gray-700 text-white rounded-full px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 border border-gray-600 placeholder-gray-400" autocomplete="off">
                    <button type="submit" id="chat-send-btn" class="bg-indigo-600 text-white p-2 rounded-full hover:bg-indigo-700 transition focus:outline-none">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Script for custom AI logic -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const toggleBtn = document.getElementById("chat-toggle-btn");
            const chatWindow = document.getElementById("chat-window");
            const iconOpen = document.getElementById("chat-icon-open");
            const iconClose = document.getElementById("chat-icon-close");
            
            const chatForm = document.getElementById("chat-form");
            const chatInput = document.getElementById("chat-input");
            const chatMessages = document.getElementById("chat-messages");

            // Toggle Chat Modal
            toggleBtn.addEventListener("click", () => {
                const isHidden = chatWindow.classList.contains("hidden");
                if (isHidden) {
                    chatWindow.classList.remove("hidden");
                    chatWindow.classList.add("flex");
                    iconOpen.classList.add("hidden");
                    iconClose.classList.remove("hidden");
                    setTimeout(() => chatInput.focus(), 100);
                } else {
                    chatWindow.classList.add("hidden");
                    chatWindow.classList.remove("flex");
                    iconOpen.classList.remove("hidden");
                    iconClose.classList.add("hidden");
                }
            });

            // Handle Message Submission
            chatForm.addEventListener("submit", async (e) => {
                e.preventDefault();
                const message = chatInput.value.trim();
                if (!message) return;

                // Add User Message
                addMessageToChat(message, "user");
                chatInput.value = "";
                
                // Show Loading
                const loadingIndicatorId = addLoadingIndicator();

                try {
                    // Send to backend C# Controller
                    const response = await fetch("/api/AiChat", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ message: message })
                    });
                    
                    const data = await response.json();
                    
                    // Remove loading and add response
                    removeMessage(loadingIndicatorId);
                    
                    if (response.ok && data.reply) {
                        addMessageToChat(data.reply, "bot");
                    } else {
                        addMessageToChat("Hata: " + (data.error || "Beklenmeyen bir hata oluştu. Lütfen Gemini API Key'in appsettings.json'da geçerli olduğundan emin ol."), "bot");
                    }

                } catch (error) {
                    removeMessage(loadingIndicatorId);
                    addMessageToChat("Sistem hatası. Sunucuya ulaşılamıyor. Controller çalışıyor mu?", "bot");
                    console.error("AI Fetch Error:", error);
                }
            });

            function addMessageToChat(text, sender) {
                const wrapper = document.createElement("div");
                wrapper.className = `flex ${sender === 'user' ? 'justify-end' : 'items-start'} mb-4`;
                
                const bubble = document.createElement("div");
                if (sender === 'user') {
                    bubble.className = "bg-indigo-600 text-white p-3 rounded-2xl rounded-tr-none max-w-[80%] text-sm shadow";
                } else {
                    bubble.className = "bg-gray-700 text-gray-100 p-3 rounded-2xl rounded-tl-none max-w-[80%] text-sm shadow";
                }
                
                // Convert simple line breaks to <br> for better readability
                bubble.innerHTML = text.replace(/(?:\r\n|\r|\n)/g, '<br>');
                
                wrapper.appendChild(bubble);
                chatMessages.appendChild(wrapper);
                scrollToBottom();
            }

            function addLoadingIndicator() {
                const id = "loading-" + Date.now();
                const wrapper = document.createElement("div");
                wrapper.id = id;
                wrapper.className = "flex items-start mb-4";
                wrapper.innerHTML = `
                    <div class="bg-gray-700 p-4 flex gap-1 rounded-2xl rounded-tl-none items-center shadow">
                        <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce"></div>
                        <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
                        <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0.4s"></div>
                    </div>
                `;
                chatMessages.appendChild(wrapper);
                scrollToBottom();
                return id;
            }

            function removeMessage(id) {
                const el = document.getElementById(id);
                if (el) el.remove();
            }

            function scrollToBottom() {
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>